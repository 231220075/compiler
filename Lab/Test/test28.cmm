struct Pair
{
    int a;
    int b;
}

int add(int x, int y)
{
    int t;
    t = x + y;
    return t;
}

int calc(int n)
{
    int arr[4];
    struct Pair p;
    int i;

    i = 0;
    p.a = 1;
    p.b = 2;

    while (i < 4)
    {
        arr[i] = add(p.a, p.b);
        i = i + 1;
    }

    if (n > 0)
        return arr[0];
    else
        return arr[1];
}

int main()
{
    int ans;
    ans = calc(3);
    return ans;
}
